# Backend Environment Variables Configuration
# Copy this to .env and fill in your values

# Application
DEBUG=false
ENVIRONMENT=production
PORT=8000

# Security
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_sre_agent
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis (optional)
# REDIS_URL=redis://localhost:6379/0

# LLM Provider Configuration
LLM_PROVIDER=ollama  # ollama or openai

# Ollama Configuration (default)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=2000
OLLAMA_TEMPERATURE=0.7

# OpenAI Configuration (only if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4
# OPENAI_MAX_TOKENS=2000

# Microservices
AI_ENGINE_URL=http://ai-engine:8001
COLLECTOR_URL=http://collector:8002
EXECUTOR_URL=http://executor:8003

# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BUCKET_ARTIFACTS=your-project-artifacts

# Kubernetes
K8S_IN_CLUSTER=true
# KUBECONFIG_PATH=/path/to/kubeconfig  # Only for local development

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Authentication
AUTH_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Feature Flags
ENABLE_CHAT=true
ENABLE_AUTO_REMEDIATION=false
ENABLE_APPROVAL_WORKFLOW=true

# Storage
VECTOR_DB_PATH=/data/vector_db
EMBEDDINGS_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# Timeouts
REQUEST_TIMEOUT=300
GRACEFUL_SHUTDOWN_TIMEOUT=30
